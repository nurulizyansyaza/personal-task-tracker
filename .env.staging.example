# ============================================
# Staging / Production Environment Variables
# ============================================
# These should be set as GitHub Secrets for CI/CD

# AWS
AWS_ACCOUNT_ID=123456789012
AWS_REGION=ap-southeast-1

# Database (RDS)
DB_HOST=your-rds-endpoint.region.rds.amazonaws.com
DB_USERNAME=taskuser
DB_PASSWORD=your-secure-password
DB_DATABASE=task_tracker_staging

# App
CORS_ORIGIN=http://your-staging-domain.com
NEXT_PUBLIC_API_URL=http://your-staging-domain.com
