# ============================================
# Staging / Production Environment Variables
# ============================================
# These should be set as GitHub Secrets for CI/CD
# or in .env files on the homelab server
#
# URL structure:
#   Production: nurulizyansyaza.com/personal-task-tracker/
#   Staging:    nurulizyansyaza.com/staging/personal-task-tracker/

# Database (MariaDB on homelab)
DB_HOST=your-homelab-ip-or-hostname
DB_USERNAME=taskuser
DB_PASSWORD=your-secure-password
DB_DATABASE=task_tracker_staging

# App
CORS_ORIGIN=https://nurulizyansyaza.com

# GitHub Secrets (set in repo settings, used by CI/CD)
# STAGING_API_URL=/staging/personal-task-tracker/api
# PRODUCTION_API_URL=/personal-task-tracker/api

# Nginx
SERVER_NAME=nurulizyansyaza.com
