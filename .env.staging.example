# ============================================
# Staging / Production Environment Variables
# ============================================
# These should be set as GitHub Secrets for CI/CD
# or in .env files on the homelab server
#
# URL structure (subdomains via Cloudflare Tunnel):
#   Production: ptt.nurulizyansyaza.com
#   Staging:    staging-ptt.nurulizyansyaza.com

# Database (MariaDB on homelab)
DB_HOST=ptt-mariadb
DB_USERNAME=taskuser
DB_PASSWORD=your-secure-password
DB_DATABASE=task_tracker_staging

# App
# Use the subdomain for the environment:
#   Staging:    https://staging-ptt.nurulizyansyaza.com
#   Production: https://ptt.nurulizyansyaza.com
CORS_ORIGIN=https://staging-ptt.nurulizyansyaza.com
